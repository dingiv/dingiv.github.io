{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    ".vitepress/**/*",
    "scripts"
  ],
  "vueCompilerOptions": {
    "target": 3.5
  },
  "ts-node": {
    "esm": true
  }
}
